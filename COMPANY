        // ========== FIXED PDF DOWNLOAD FUNCTION - A4 SIZE ==========
        async function downloadPDF() {
            const element = document.getElementById('invoicePreview');
            const loadingDiv = document.getElementById('loadingDiv');
            
            try {
                loadingDiv.style.display = 'block';
                
                await new Promise(resolve => setTimeout(resolve, 500));
                
                // Force A4 width for accurate capture
                const originalWidth = element.style.width;
                element.style.width = '210mm';
                
                const canvas = await html2canvas(element, {
                    scale: 2.5,
                    useCORS: true,
                    allowTaint: false,
                    logging: false,
                    backgroundColor: '#ffffff',
                    windowWidth: 800,
                    windowHeight: element.scrollHeight,
                    onclone: (clonedDoc, element) => {
                        const images = clonedDoc.querySelectorAll('img');
                        images.forEach(img => {
                            if (img.complete === false) {
                                img.style.display = 'block';
                            }
                        });
                    }
                });
                
                element.style.width = originalWidth;
                
                const imgData = canvas.toDataURL('image/jpeg', 1.0);
                
                if (typeof window.jspdf === 'undefined') {
                    alert('PDF library not loaded.');
                    loadingDiv.style.display = 'none';
                    return;
                }
                
                const { jsPDF } = window.jspdf;
                
                // Create A4 PDF
                const pdf = new jsPDF({
                    orientation: 'portrait',
                    unit: 'mm',
                    format: 'a4',
                    compress: true
                });
                
                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pdfHeight = pdf.internal.pageSize.getHeight();
                const imgWidth = pdfWidth;
                const imgHeight = (canvas.height * pdfWidth) / canvas.width;
                
                let heightLeft = imgHeight;
                let position = 0;
                
                pdf.addImage(imgData, 'JPEG', 0, position, imgWidth, imgHeight, '', 'FAST');
                heightLeft -= pdfHeight;
                
                while (heightLeft > 0) {
                    position = heightLeft - imgHeight;
                    pdf.addPage();
                    pdf.addImage(imgData, 'JPEG', 0, position, imgWidth, imgHeight, '', 'FAST');
                    heightLeft -= pdfHeight;
                }
                
                const filename = `${currentDocData.docTitle}_${currentDocData.docNumber}.pdf`;
                pdf.save(filename);
                
                loadingDiv.style.display = 'none';
                
            } catch (error) {
                console.error('PDF Error:', error);
                loadingDiv.style.display = 'none';
                alert('PDF download failed. Error: ' + error.message);
            }
        }

        async function downloadImage() {
            const element = document.getElementById('invoicePreview');
            const loadingDiv = document.getElementById('loadingDiv');
            
            try {
                loadingDiv.style.display = 'block';
                
                await new Promise(resolve => setTimeout(resolve, 500));
                
                const originalBg = element.style.backgroundColor;
                element.style.backgroundColor = '#ffffff';
                
                const canvas = await html2canvas(element, {
                    scale: 3,
                    useCORS: true,
                    allowTaint: false,
                    logging: false,
                    backgroundColor: '#ffffff',
                    imageTimeout: 15000,
                    scrollY: -window.scrollY,
                    scrollX: -window.scrollX
                });
                
                element.style.backgroundColor = originalBg;
                
                canvas.toBlob(function(blob) {
                    if (!blob) {
                        alert('Failed to generate image. Please try again.');
                        loadingDiv.style.display = 'none';
                        return;
                    }
                    
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `${currentDocData.docTitle}_${currentDocData.docNumber}.png`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    loadingDiv.style.display = 'none';
                    alert('Image downloaded successfully!');
                }, 'image/png', 1.0);
                
            } catch (error) {
                console.error('Image Error:', error);
                loadingDiv.style.display = 'none';
                alert('Image download failed. Error: ' + error.message);
            }
        }

        async function shareToWhatsApp() {
            const phone = currentDocData.customerPhone;
            const element = document.getElementById('invoicePreview');
            
            try {
                await new Promise(resolve => setTimeout(resolve, 500));
                
                const canvas = await html2canvas(element, {
                    scale: 2,
                    useCORS: true,
                    allowTaint: false,
                    logging: false,
                    backgroundColor: '#ffffff',
                    imageTimeout: 15000,
                    scrollY: -window.scrollY,
                    scrollX: -window.scrollX
                });
                
                canvas.toBlob(async function(blob) {
                    if (!blob) {
                        fallbackWhatsAppShare(phone);
                        return;
                    }
                    
                    if (navigator.share && navigator.canShare) {
                        const file = new File([blob], `${currentDocData.docTitle}_${currentDocData.docNumber}.png`, { 
                            type: 'image/png' 
                        });
                        
                        if (navigator.canShare({ files: [file] })) {
                            try {
                                await navigator.share({
                                    files: [file],
                                    title: `${currentDocData.docTitle} - ${currentDocData.docNumber}`,
                                    text: `${currentDocData.docTitle} from GraphicSolution.lk`
                                });
                                return;
                            } catch (shareError) {
                                if (shareError.name === 'AbortError') {
                                    return;
                                }
                            }
                        }
                    }
                    
                    downloadImageForWhatsApp(blob, phone);
                    
                }, 'image/png', 1.0);
                
            } catch (error) {
                console.error('Error generating image:', error);
                fallbackWhatsAppShare(phone);
            }
        }
        
